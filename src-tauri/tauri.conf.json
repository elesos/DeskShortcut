{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DeskShortcut",
  "version": "0.1.0",
  "identifier": "com.deskshortcut.desktop",
  "build": {
    "beforeDevCommand": "npm run dev:frontend -- --host 127.0.0.1",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build:frontend",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "DeskShortcut",
        "width": 420,
        "height": 640,
        "minWidth": 360,
        "minHeight": 460,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": false,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    },
    "shortDescription": "Desktop shortcut manager",
    "longDescription": "DeskShortcut collects Windows desktop shortcuts and launches them with preserved arguments and working directories."
  }
}
